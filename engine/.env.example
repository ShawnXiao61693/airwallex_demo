# 复制为 .env 并填入你的 key（.env 已被 .gitignore，不会进 Git）
# OpenAI 兼容接口；用 Kimi 就填 Kimi 的 base_url/model
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
# 数据源 Brave Search API
BRAVE_API_KEY=
# 数据库 Supabase（pooler 连接串，URL 形式，密码需百分号编码）
DATABASE_URL=postgresql://postgres.xxx:ENCODED_PW@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# 周报上传 API 的鉴权 token（任意随机串；上传方需带 X-Api-Token 头）
API_TOKEN=
